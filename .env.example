# Shared
NODE_ENV=development
APP_NAME="Dheel Plus Rent OS"
APP_URL=http://localhost:3000
API_URL=http://localhost:4000/api

# Database
DATABASE_URL="postgresql://dheel:dheel@localhost:5432/dheel_plus?schema=public"
REDIS_URL="redis://localhost:6379"

# Storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=dheel-plus
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Auth
JWT_ACCESS_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me
OTP_PROVIDER=mock

# Payments
PAYMENT_PROVIDER=moyasar
MOYASAR_SECRET_KEY=
TAP_SECRET_KEY=
HYPERPAY_ENTITY_ID=

# Notifications
SMS_PROVIDER=mock
UNIFONIC_API_KEY=
TAQNYAT_API_KEY=
EMAIL_SMTP_URL=
FIREBASE_SERVER_KEY=

# WhatsApp / CRM

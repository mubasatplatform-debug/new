# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database (Supabase / Neon) ───────────────────────────────────────────────
# Direct connection — for migrations
DATABASE_DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Pooled connection (PgBouncer) — for app queries
DATABASE_URL=postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # NEVER expose this on the client

# ─── Authentication (better-auth) ─────────────────────────────────────────────
BETTER_AUTH_SECRET=   # openssl rand -base64 32

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Upstash Redis (Rate Limiting + Idempotency) ──────────────────────────────
UPSTASH_REDIS_REST_URL=https://[HASH].upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ─── Payment Gateways ─────────────────────────────────────────────────────────
# Moyasar (GCC)
MOYASAR_PUBLIC_KEY=pk_test_...
MOYASAR_SECRET_KEY=sk_test_...
MOYASAR_WEBHOOK_SECRET=   # From Moyasar dashboard

# Stripe (Global)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # stripe listen --print-secret

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=eSIM Platform <noreply@yourdomain.com>

# ─── WhatsApp (Infobip) ───────────────────────────────────────────────────────
# REST API + hosted MCP server: https://mcp.infobip.com/whatsapp
INFOBIP_API_KEY=                              # Infobip API key (used as: Authorization: App <key>)
INFOBIP_BASE_URL=xxxxx.api.infobip.com        # Your account base URL (no protocol needed)
INFOBIP_WHATSAPP_SENDER=                       # Registered WhatsApp sender number (MSISDN, no +)
INFOBIP_WHATSAPP_LANGUAGE=ar                    # Default template language
INFOBIP_TEMPLATE_ESIM_DELIVERY=esim_delivery   # Approved template name for eSIM delivery
INFOBIP_TEMPLATE_ORDER_CONFIRMATION=order_confirmation  # Approved template name for order confirmation

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── eSIM Provider ────────────────────────────────────────────────────────────
ESIM_PROVIDER_API_URL=https://api.yourprovider.com
ESIM_PROVIDER_API_KEY=

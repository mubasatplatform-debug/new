{
  "name": "dheel-plus-rent-os",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @dheel/web dev",
    "dev:api": "pnpm --filter @dheel/api start:dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @dheel/api prisma:generate",
    "db:migrate": "pnpm --filter @dheel/api prisma:migrate",
    "db:seed": "pnpm --filter @dheel/api prisma:seed"
  }
}
